{
  "name": "innenu-resource",
  "private": true,
  "description": "inNENU 小程序资源文件",
  "license": "Mr.Hope LICENSE",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:inNENU/resource.git"
  },
  "type": "module",
  "scripts": {
    "assets:check": "unrun ./scripts/check-assets.ts",
    "commit:force": "git commit --no-verify",
    "knowledge:generate": "unrun ./scripts/generate-knowledge.ts",
    "lint": "oxlint --fix --report-unused-disable-directives --deny-warnings && oxfmt",
    "lint:check": "oxlint --report-unused-disable-directives --deny-warnings && oxfmt --check",
    "prepare": "husky",
    "push-pages": "unrun ./scripts/push-pages.ts",
    "resource:check": "unrun ./scripts/check-resource.ts",
    "resource:copy": "unrun ./scripts/copy-resources.ts",
    "resource:generate": "unrun ./scripts/generate-resource.ts",
    "serve": "unrun ./scripts/server.ts",
    "site:build": "vuepress build .site",
    "site:dev": "vuepress dev .site",
    "site:generate": "unrun ./scripts/generate-site.ts",
    "sync:account": "unrun ./scripts/sync-account.ts",
    "sync:oss": "unrun ./scripts/sync-oss.ts",
    "text:generate": "unrun ./scripts/generate-text.ts"
  },
  "dependencies": {
    "@alicloud/cdn20180510": "9.2.0",
    "@mdit-vue/plugin-frontmatter": "3.0.2",
    "@vuepress/bundler-vite": "2.0.0-rc.30",
    "@vuepress/helper": "2.0.0-rc.130",
    "@vuepress/plugin-feed": "2.0.0-rc.130",
    "@vuepress/plugin-meilisearch": "2.0.0-rc.130",
    "@vueuse/core": "14.3.0",
    "cheerio": "1.2.0",
    "cpx2": "9.0.0",
    "del": "8.0.1",
    "dotenv": "17.4.2",
    "innenu-generator": "0.8.2",
    "js-yaml": "5.0.0",
    "markdown-it": "14.2.0",
    "sass-embedded": "1.100.0",
    "vidstack": "1.12.13",
    "vue": "3.5.38",
    "vuepress": "2.0.0-rc.30",
    "vuepress-shared": "2.0.0-rc.107",
    "vuepress-theme-hope": "2.0.0-rc.107"
  },
  "devDependencies": {
    "@mr-hope/tsconfig": "0.0.4",
    "@types/js-yaml": "4.0.9",
    "@types/markdown-it": "14.1.2",
    "@types/node": "24.13.2",
    "domhandler": "6.0.1",
    "husky": "9.1.7",
    "nano-staged": "1.0.2",
    "oxc-config-hope": "0.3.9",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "svgo": "4.0.1",
    "typescript": "6.0.3",
    "unrun": "0.3.1",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --type-check --type-aware --report-unused-disable-directives"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^24.16.0",
      "onFail": "error"
    }
  }
}
